    TweenService:Create(exitBtn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(40, 40, 40)}):Play()
    TweenService:Create(exitBtn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 118, 0, 42)}):Play()
