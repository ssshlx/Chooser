local Players = game:GetService("Players")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "LoadstringSelector"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

local mainFrame = Instance.new("Frame")
mainFrame.Name = "MainFrame"
mainFrame.Size = UDim2.new(0, 300, 0, 380)
mainFrame.Position = UDim2.new(0.5, -150, 0.5, -190)
mainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
mainFrame.BorderSizePixel = 0
mainFrame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = mainFrame

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(50, 50, 50)
stroke.Thickness = 1
stroke.Parent = mainFrame

local titleLabel = Instance.new("TextLabel")
titleLabel.Size = UDim2.new(1, 0, 0, 40)
titleLabel.Position = UDim2.new(0, 0, 0, 0)
titleLabel.BackgroundTransparency = 1
titleLabel.Text = "Selecciona tus Scripts"
titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
titleLabel.TextSize = 18
titleLabel.Font = Enum.Font.GothamBold
titleLabel.Parent = mainFrame

local selected = {
    OPT = false,
    LH = false,
    SKG = false,
    CRIM = false,
    ADC = false
}

local buttons = {}

local adcBtn = Instance.new("TextButton")
adcBtn.Name = "ADC"
adcBtn.Size = UDim2.new(0, 240, 0, 35)
adcBtn.Position = UDim2.new(0.5, -120, 0, 230)
adcBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
adcBtn.Text = "Admin Check"
adcBtn.TextColor3 = Color3.fromRGB(255, 215, 0)
adcBtn.TextSize = 14
adcBtn.Font = Enum.Font.GothamSemibold
adcBtn.BorderSizePixel = 0
adcBtn.Visible = false
adcBtn.Parent = mainFrame

local adcCorner = Instance.new("UICorner")
adcCorner.CornerRadius = UDim.new(0, 6)
adcCorner.Parent = adcBtn

local adcStroke = Instance.new("UIStroke")
adcStroke.Color = Color3.fromRGB(255, 215, 0)
adcStroke.Thickness = 2
adcStroke.Transparency = 0.7
adcStroke.Parent = adcBtn

adcBtn.MouseButton1Click:Connect(function()
    selected.ADC = not selected.ADC
    if selected.ADC then
        adcBtn.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
        adcBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
        adcStroke.Transparency = 0
    else
        adcBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        adcBtn.TextColor3 = Color3.fromRGB(255, 215, 0)
        adcStroke.Transparency = 0.7
    end
end)

local function createOptionButton(id, displayName, color, yPos)
    local btn = Instance.new("TextButton")
    btn.Name = id
    btn.Size = UDim2.new(0, 240, 0, 40)
    btn.Position = UDim2.new(0.5, -120, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.Text = displayName
    btn.TextColor3 = color
    btn.TextSize = 16
    btn.Font = Enum.Font.GothamSemibold
    btn.BorderSizePixel = 0
    btn.Parent = mainFrame

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn

    local btnStroke = Instance.new("UIStroke")
    btnStroke.Color = color
    btnStroke.Thickness = 2
    btnStroke.Transparency = 0.7
    btnStroke.Parent = btn

    buttons[id] = {button = btn, stroke = btnStroke, color = color}

    btn.MouseButton1Click:Connect(function()
        selected[id] = not selected[id]
        if selected[id] then
            btn.BackgroundColor3 = color
            btn.TextColor3 = Color3.fromRGB(0, 0, 0)
            btnStroke.Transparency = 0
        else
            btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            btn.TextColor3 = color
            btnStroke.Transparency = 0.7
        end
        
        if id == "LH" then
            if selected.LH then
                adcBtn.Visible = true
            else
                adcBtn.Visible = false
                selected.ADC = false
                adcBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                adcBtn.TextColor3 = Color3.fromRGB(255, 215, 0)
                adcStroke.Transparency = 0.7
            end
        end
    end)
end

createOptionButton("OPT", "LH Optimizer", Color3.fromRGB(70, 130, 255), 50)
createOptionButton("LH", "Legit Hub", Color3.fromRGB(50, 205, 50), 95)
createOptionButton("SKG", "Skin Changer", Color3.fromRGB(160, 160, 160), 140)
createOptionButton("CRIM", "JX", Color3.fromRGB(255, 50, 50), 185)

local confirmBtn = Instance.new("TextButton")
confirmBtn.Name = "Confirm"
confirmBtn.Size = UDim2.new(0, 115, 0, 40)
confirmBtn.Position = UDim2.new(0.5, -120, 0, 275)
confirmBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
confirmBtn.Text = "Ejecutar"
confirmBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
confirmBtn.TextSize = 15
confirmBtn.Font = Enum.Font.GothamBold
confirmBtn.BorderSizePixel = 0
confirmBtn.Parent = mainFrame

local confirmCorner = Instance.new("UICorner")
confirmCorner.CornerRadius = UDim.new(0, 6)
confirmCorner.Parent = confirmBtn

local confirmStroke = Instance.new("UIStroke")
confirmStroke.Color = Color3.fromRGB(80, 80, 80)
confirmStroke.Thickness = 1
confirmStroke.Parent = confirmBtn

local exitBtn = Instance.new("TextButton")
exitBtn.Name = "Exit"
exitBtn.Size = UDim2.new(0, 115, 0, 40)
exitBtn.Position = UDim2.new(0.5, 5, 0, 275)
exitBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
exitBtn.Text = "Salir"
exitBtn.TextColor3 = Color3.fromRGB(255, 80, 80)
exitBtn.TextSize = 15
exitBtn.Font = Enum.Font.GothamBold
exitBtn.BorderSizePixel = 0
exitBtn.Parent = mainFrame

local exitCorner = Instance.new("UICorner")
exitCorner.CornerRadius = UDim.new(0, 6)
exitCorner.Parent = exitBtn

local exitStroke = Instance.new("UIStroke")
exitStroke.Color = Color3.fromRGB(80, 80, 80)
exitStroke.Thickness = 1
exitStroke.Parent = exitBtn

confirmBtn.MouseButton1Click:Connect(function()
    screenGui:Destroy()

    if selected.OPT then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/ssshlx/legitOpt/refs/heads/main/opt"))()
    end

    if selected.LH then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/ssshlx/ESPAIMBOT/refs/heads/main/Hub"))()
        if selected.ADC then
            loadstring(game:HttpGet("https://raw.githubusercontent.com/ssshlx/ADC/refs/heads/main/Main"))()
        end
    end

    if selected.SKG then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/ssshlx/CSKG/refs/heads/main/skn"))()
    end

    if selected.CRIM then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/ssshlx/CRIM/refs/heads/main/MOD"))()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/ssshlx/ADC/refs/heads/main/Main"))()
    end
end)

exitBtn.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)
