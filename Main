local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "LoadstringSelector"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

local mainFrame = Instance.new("Frame")
mainFrame.Name = "MainFrame"
mainFrame.Size = UDim2.new(0, 300, 0, 425)
mainFrame.Position = UDim2.new(0.5, -150, 0.5, -212)
mainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
mainFrame.BorderSizePixel = 0
mainFrame.BackgroundTransparency = 1
mainFrame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = mainFrame

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(50, 50, 50)
stroke.Thickness = 1
stroke.Transparency = 1
stroke.Parent = mainFrame

local titleLabel = Instance.new("TextLabel")
titleLabel.Size = UDim2.new(1, 0, 0, 40)
titleLabel.Position = UDim2.new(0, 0, 0, 0)
titleLabel.BackgroundTransparency = 1
titleLabel.Text = "Selecciona tus Scripts"
titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
titleLabel.TextSize = 18
titleLabel.Font = Enum.Font.GothamBold
titleLabel.TextTransparency = 1
titleLabel.Parent = mainFrame

local selected = {
    OPT = false,
    LH = false,
    SKG = false,
    CRIM = false,
    TB = false,
    ADC = false
}

local buttons = {}

local adcBtn = Instance.new("TextButton")
adcBtn.Name = "ADC"
adcBtn.Size = UDim2.new(0, 240, 0, 35)
adcBtn.Position = UDim2.new(0.5, -120, 0, 275)
adcBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
adcBtn.Text = "Admin Check"
adcBtn.TextColor3 = Color3.fromRGB(255, 215, 0)
adcBtn.TextSize = 14
adcBtn.Font = Enum.Font.GothamSemibold
adcBtn.BorderSizePixel = 0
adcBtn.Visible = false
adcBtn.BackgroundTransparency = 1
adcBtn.TextTransparency = 1
adcBtn.Parent = mainFrame

local adcCorner = Instance.new("UICorner")
adcCorner.CornerRadius = UDim.new(0, 6)
adcCorner.Parent = adcBtn

local adcStroke = Instance.new("UIStroke")
adcStroke.Color = Color3.fromRGB(255, 215, 0)
adcStroke.Thickness = 2
adcStroke.Transparency = 1
adcStroke.Parent = adcBtn

adcBtn.MouseButton1Click:Connect(function()
    selected.ADC = not selected.ADC
    if selected.ADC then
        TweenService:Create(adcBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(255, 215, 0), TextColor3 = Color3.fromRGB(0, 0, 0)}):Play()
        TweenService:Create(adcStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Transparency = 0}):Play()
    else
        TweenService:Create(adcBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(30, 30, 30), TextColor3 = Color3.fromRGB(255, 215, 0)}):Play()
        TweenService:Create(adcStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Transparency = 0.7}):Play()
    end
end)

local function createOptionButton(id, displayName, color, yPos)
    local btn = Instance.new("TextButton")
    btn.Name = id
    btn.Size = UDim2.new(0, 240, 0, 40)
    btn.Position = UDim2.new(0.5, -120, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.Text = displayName
    btn.TextColor3 = color
    btn.TextSize = 16
    btn.Font = Enum.Font.GothamSemibold
    btn.BorderSizePixel = 0
    btn.BackgroundTransparency = 1
    btn.TextTransparency = 1
    btn.Parent = mainFrame

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn

    local btnStroke = Instance.new("UIStroke")
    btnStroke.Color = color
    btnStroke.Thickness = 2
    btnStroke.Transparency = 1
    btnStroke.Parent = btn

    buttons[id] = {button = btn, stroke = btnStroke, color = color}

    btn.MouseEnter:Connect(function()
        if not selected[id] then
            TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(40, 40, 40)}):Play()
        end
        TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 245, 0, 42)}):Play()
    end)

    btn.MouseLeave:Connect(function()
        if not selected[id] then
            TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(30, 30, 30)}):Play()
        end
        TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 240, 0, 40)}):Play()
    end)

    btn.MouseButton1Click:Connect(function()
        selected[id] = not selected[id]
        if selected[id] then
            TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = color, TextColor3 = Color3.fromRGB(0, 0, 0)}):Play()
            TweenService:Create(btnStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Transparency = 0}):Play()
        else
            TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(30, 30, 30), TextColor3 = color}):Play()
            TweenService:Create(btnStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Transparency = 0.7}):Play()
        end
        
        if id == "LH" then
            if selected.LH then
                adcBtn.Visible = true
                TweenService:Create(adcBtn, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {BackgroundTransparency = 0, TextTransparency = 0}):Play()
                TweenService:Create(adcStroke, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Transparency = 0.7}):Play()
            else
                TweenService:Create(adcBtn, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {BackgroundTransparency = 1, TextTransparency = 1}):Play()
                TweenService:Create(adcStroke, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Transparency = 1}):Play()
                task.wait(0.3)
                adcBtn.Visible = false
                selected.ADC = false
                adcBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                adcBtn.TextColor3 = Color3.fromRGB(255, 215, 0)
            end
        end
    end)
end

createOptionButton("OPT", "LH Optimizer", Color3.fromRGB(70, 130, 255), 50)
createOptionButton("LH", "Legit Hub", Color3.fromRGB(50, 205, 50), 95)
createOptionButton("SKG", "Skin Changer", Color3.fromRGB(160, 160, 160), 140)
createOptionButton("CRIM", "JX", Color3.fromRGB(255, 50, 50), 185)
createOptionButton("TB", "Trigger Bot", Color3.fromRGB(150, 50, 200), 230)

