    TweenService:Create(exitBtn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(25, 25, 25)}):Play()
    TweenService:Create(exitBtn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 115, 0, 40)}):Play()
end)

confirmBtn.MouseButton1Click:Connect(function()
    TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {BackgroundTransparency = 1, Position = UDim2.new(0.5, -150, 0.5, -250)}):Play()
    TweenService:Create(stroke, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Transparency = 1}):Play()
    task.wait(0.3)
    screenGui:Destroy()

    if selected.OPT then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/ssshlx/legitOpt/refs/heads/main/opt"))()
    end

    if selected.LH then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/ssshlx/ESPAIMBOT/refs/heads/main/Hub"))()
        if selected.ADC then
            loadstring(game:HttpGet("https://raw.githubusercontent.com/ssshlx/ADC/refs/heads/main/Main"))()
        end
    end

    if selected.SKG then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/ssshlx/CSKG/refs/heads/main/skn"))()
    end

    if selected.CRIM then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/ssshlx/CRIM/refs/heads/main/MOD"))()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/ssshlx/ADC/refs/heads/main/Main"))()
    end

    if selected.TB then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/ssshlx/TB/refs/heads/main/Main"))()
    end
end)

exitBtn.MouseButton1Click:Connect(function()
    TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {BackgroundTransparency = 1, Position = UDim2.new(0.5, -150, 0.5, -250)}):Play()
    TweenService:Create(stroke, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Transparency = 1}):Play()
    task.wait(0.3)
    screenGui:Destroy()
end)

task.wait(0.1)
mainFrame.Position = UDim2.new(0.5, -150, 0.5, -180)
TweenService:Create(mainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {BackgroundTransparency = 0, Position = UDim2.new(0.5, -150, 0.5, -212)}):Play()
TweenService:Create(stroke, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Transparency = 0}):Play()
TweenService:Create(titleLabel, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()

for id, data in pairs(buttons) do
    TweenService:Create(data.button, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {BackgroundTransparency = 0, TextTransparency = 0}):Play()
    TweenService:Create(data.stroke, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Transparency = 0.7}):Play()
end

TweenService:Create(confirmBtn, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {BackgroundTransparency = 0, TextTransparency = 0}):Play()
